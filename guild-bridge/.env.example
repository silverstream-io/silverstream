# Required: shared secret — use the same value in Guild as the BYOI API key
BRIDGE_API_KEY=generate_a_long_random_string

# IMAP (stays on the bridge host, never in the Guild agent)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASSWORD=app-specific-password
IMAP_TLS=1
IMAP_MAILBOX=INBOX
IMAP_MAX_MESSAGES=20
# IMAP_MARK_SEEN=0

# Twilio (stays on the bridge host; SMS target is not exposed to the agent)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_FROM=+15551234567
SMS_TO=+15557654321

PORT=8080
